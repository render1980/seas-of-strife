{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "init-db": "bun run scripts/init-db.ts",
    "dev": "bun --watch index.ts",
    "fmt": "npx prettier --write '**/*.ts'",
    "test": "bun test tests/game/*",
    "test:db": "bun run scripts/create-test-db.ts && bun test --preload ./tests/db/helpers/setup.ts tests/db/; code=$?; bun run scripts/drop-test-db.ts; exit $code"
  },
  "dependencies": {
    "postgres": "^3.4"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
